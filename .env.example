# MySQL
MYSQL_USER=root
MYSQL_PASSWORD=8888.216
MYSQL_ADDR=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=local_review_go
# 分布式部署时每实例建议 30，避免 3 实例 × 100 超过 MySQL max_connections
# MYSQL_MAX_OPEN_CONNS=30

# Redis
REDIS_ADDR=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=8888.216

# JWT（生产环境务必修改，多实例必须一致）
JWT_SECRET_KEY=local-review-key-change-in-production

# 秒杀限流（8G 内存建议 50/80，16G+ 可调高）
# SECKILL_RATE_LIMIT=50
# SECKILL_RATE_BURST=80

# 登录限流（压测 51 用户时需调高，否则仅 5 用户能登录）
# LOGIN_RATE_LIMIT=120
# LOGIN_RATE_BURST=60

# RocketMQ（秒杀异步消费）
ROCKETMQ_NAMESRV_ADDR=127.0.0.1:9876
ROCKETMQ_TOPIC_SECKILL=seckill-orders
ROCKETMQ_PRODUCER_GROUP=seckill-producer-group
ROCKETMQ_CONSUMER_GROUP=seckill-consumer-group

# 分布式部署：日志与可观测性
# LOG_FORMAT=json
# INSTANCE_ID=go-app-1
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
